local HTTP = (cloneref and cloneref(game:GetService("HttpService"))) or game:GetService("HttpService")
local VURL = "https://raw.githubusercontent.com/audio-wav/unexpected-cmd/main/version"
local SURL = "https://raw.githubusercontent.com/audio-wav/unexpected-cmd/main/source"
local CACHE = isfile("ux_cache.json") and HTTP:JSONDecode(readfile("ux_cache.json")) or nil
local REMOTE = HTTP:JSONDecode(game:HttpGet(VURL))
if not CACHE or CACHE.version ~= REMOTE.version then
    writefile("ux_source.lua", game:HttpGet(SURL))
    writefile("ux_cache.json", HTTP:JSONEncode(REMOTE))
end

loadstring(readfile("ux_source.lua"))()
